{
  "name": "labzz/chat",
  "description": "Realtime chat system for Labzz Fullstack Challenge",
  "type": "project",
  "require": {
    "php": "^8.1",
    "cboden/ratchet": "^0.4.4",
    "elasticsearch/elasticsearch": "^8.0",
    "firebase/php-jwt": "^7.0",
    "predis/predis": "^3.4",
    "vlucas/phpdotenv": "^5.6",
    "zircote/swagger-php": "^6.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "serve": "php -S localhost:8000 -t public",
    "ws": "php websocket-server.php"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
